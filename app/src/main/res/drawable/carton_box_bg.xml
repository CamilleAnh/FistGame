<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base Wood Color (Main Body) -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#8B4513" /> <!-- SaddleBrown -->
            <corners android:radius="4dp" />
            <stroke android:width="3dp" android:color="#5D4037" />
        </shape>
    </item>

    <!-- Horizontal Planks Detail -->
    <!-- Top Plank -->
    <item android:bottom="70dp" android:top="4dp" android:left="4dp" android:right="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#A0522D" /> <!-- Sienna -->
            <stroke android:width="1dp" android:color="#3E2723" />
        </shape>
    </item>

    <!-- Middle Plank -->
    <item android:top="40dp" android:bottom="40dp" android:left="4dp" android:right="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#964B00" /> <!-- Brown -->
            <stroke android:width="1dp" android:color="#3E2723" />
        </shape>
    </item>

    <!-- Bottom Plank -->
    <item android:top="70dp" android:bottom="4dp" android:left="4dp" android:right="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#6F4E37" /> <!-- Coffee -->
            <stroke android:width="1dp" android:color="#3E2723" />
        </shape>
    </item>

    <!-- Vertical Side Braces (Supports) -->
    <item android:width="12dp" android:gravity="left" android:top="2dp" android:bottom="2dp" android:left="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#5D4037" />
        </shape>
    </item>
    <item android:width="12dp" android:gravity="right" android:top="2dp" android:bottom="2dp" android:right="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#5D4037" />
        </shape>
    </item>

    <!-- Inner Shadow for Depth (Where items are placed) -->
    <item android:top="8dp" android:left="8dp" android:right="8dp" android:bottom="12dp">
        <shape android:shape="rectangle">
            <solid android:color="#22000000" />
            <corners android:radius="2dp" />
        </shape>
    </item>
</layer-list>