<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 1. Bottom Shadow (Perspective Drop Shadow) -->
    <item android:top="12dp" android:left="8dp" android:right="2dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="#33000000" />
            <corners android:radius="8dp" />
        </shape>
    </item>

    <!-- 2. Main Box Body (The Bottom & Sides) -->
    <item android:bottom="4dp" android:right="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#5D4037" />
            <corners android:radius="10dp" />
            <stroke android:width="2dp" android:color="#3E2723" />
        </shape>
    </item>

    <!-- 3. Top Rim / Perspective View -->
    <item android:bottom="14dp" android:right="4dp">
        <shape android:shape="rectangle">
            <gradient 
                android:startColor="#8D6E63" 
                android:endColor="#5D4037" 
                android:angle="270" />
            <corners android:radius="10dp" />
        </shape>
    </item>

    <!-- 4. Front Panel (Brightest Part) -->
    <item android:top="8dp" android:bottom="6dp" android:left="2dp" android:right="6dp">
        <shape android:shape="rectangle">
            <gradient 
                android:startColor="#D7CCC8" 
                android:centerColor="#BCAAA4" 
                android:endColor="#A1887F" 
                android:angle="90" />
            <corners android:radius="6dp" />
            <stroke android:width="1dp" android:color="#795548" />
        </shape>
    </item>

    <!-- 5. Vertical Wood Texture on Front -->
    <item android:width="8dp" android:gravity="left" android:left="6dp" android:top="12dp" android:bottom="10dp">
        <shape android:shape="rectangle">
            <solid android:color="#225D4037" />
        </shape>
    </item>
    <item android:width="8dp" android:gravity="right" android:right="12dp" android:top="12dp" android:bottom="10dp">
        <shape android:shape="rectangle">
            <solid android:color="#225D4037" />
        </shape>
    </item>

    <!-- 6. Inner Hole Shadow (Where fruit goes) -->
    <item android:top="2dp" android:left="8dp" android:right="12dp" android:bottom="20dp">
        <shape android:shape="rectangle">
            <solid android:color="#44000000" />
            <corners android:radius="4dp" />
        </shape>
    </item>
</layer-list>
