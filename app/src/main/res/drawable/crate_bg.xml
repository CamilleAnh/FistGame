<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base wood color -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#A0522D" />
            <corners android:radius="4dp" />
            <stroke android:width="2dp" android:color="#5D4037" />
        </shape>
    </item>
    <!-- Top plank -->
    <item android:bottom="30dp">
        <shape android:shape="rectangle">
            <solid android:color="#8D6E63" />
            <stroke android:width="1dp" android:color="#5D4037" />
        </shape>
    </item>
    <!-- Middle plank -->
    <item android:top="15dp" android:bottom="15dp">
        <shape android:shape="rectangle">
            <solid android:color="#795548" />
            <stroke android:width="1dp" android:color="#4E342E" />
        </shape>
    </item>
    <!-- Bottom plank -->
    <item android:top="30dp">
        <shape android:shape="rectangle">
            <solid android:color="#6D4C41" />
            <stroke android:width="1dp" android:color="#3E2723" />
        </shape>
    </item>
    <!-- Cross strap (Dán icon lên đây) -->
    <item android:left="8dp" android:right="8dp" android:top="8dp" android:bottom="8dp">
        <shape android:shape="rectangle">
            <solid android:color="#BCAAA4" />
            <corners android:radius="2dp" />
            <alpha android:alpha="0.3" />
        </shape>
    </item>
</layer-list>