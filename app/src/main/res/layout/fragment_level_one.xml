<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/back">

    <TextView
        android:id="@+id/tv_level_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="LEVEL 1"
        android:textColor="#FFD54F"
        android:textSize="22sp"
        android:textStyle="bold"
        android:shadowColor="#000000"
        android:shadowDx="2"
        android:shadowDy="2"
        android:shadowRadius="2"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Gold display (top-left, nhỏ gọn) -->
    <TextView
        android:id="@+id/tv_game_gold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="12dp"
        android:text="🪙 0"
        android:textColor="#FFD54F"
        android:textSize="14sp"
        android:textStyle="bold"
        android:background="#44000000"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="3dp"
        android:paddingBottom="3dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/btn_settings"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/ic_menu_manage"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#FFFFFF" />

    <TextView
        android:id="@+id/tv_instruction"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:gravity="center"
        android:text="..."
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:shadowColor="#000000"
        android:shadowDx="1"
        android:shadowDy="1"
        android:shadowRadius="2"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_level_name" />

    <LinearLayout
        android:id="@+id/ll_boxes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="16dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:weightSum="2"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_instruction">

        <TextView
            android:id="@+id/tv_box_a"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:gravity="center"
            android:padding="8dp"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:shadowColor="#000000"
            android:shadowRadius="1" />

        <TextView
            android:id="@+id/tv_box_b"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:gravity="center"
            android:padding="8dp"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:shadowColor="#000000"
            android:shadowRadius="1" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_packed_progress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="..."
        android:textColor="#FFEB3B"
        android:textSize="14sp"
        android:textStyle="bold"
        android:shadowColor="#000000"
        android:shadowDx="1"
        android:shadowDy="1"
        android:shadowRadius="2"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/ll_boxes" />

    <!-- Power-up bar -->
    <LinearLayout
        android:id="@+id/ll_powerups"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_packed_progress">

        <!-- 🎲 Roll túi -->
        <Button
            android:id="@+id/btn_reroll_bags"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:layout_marginEnd="6dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="🎲 ×1"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:backgroundTint="#E65100"
            android:elevation="6dp"
            android:stateListAnimator="@null" />

        <!-- 🔍 Kính lúp -->
        <Button
            android:id="@+id/btn_magnify"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:layout_marginEnd="6dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="🔍 ×1"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:backgroundTint="#0D47A1"
            android:elevation="6dp"
            android:stateListAnimator="@null" />

        <!-- 🔀 Shuffle -->
        <Button
            android:id="@+id/btn_reshuffle"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="🔀 ×1"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:backgroundTint="#6A1B9A"
            android:elevation="6dp"
            android:stateListAnimator="@null" />
    </LinearLayout>

    <GridLayout
        android:id="@+id/gl_game_board"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="4dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:columnCount="4"
        android:alignmentMode="alignMargins"
        app:layout_constraintBottom_toTopOf="@+id/btn_next_level"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/ll_powerups" />

    <Button
        android:id="@+id/btn_next_level"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="NEXT LEVEL"
        android:visibility="gone"
        android:backgroundTint="#4CAF50"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/ll_actions"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <LinearLayout
        android:id="@+id/ll_actions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toTopOf="@+id/ad_container"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Nút Home -->
        <Button
            android:id="@+id/btn_back_level_select"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginEnd="12dp"
            android:text="🏠"
            android:textSize="22sp"
            android:backgroundTint="#CC2E7D32"
            android:elevation="6dp"
            android:stateListAnimator="@null" />

        <!-- Nút Reset -->
        <Button
            android:id="@+id/btn_reset"
            android:layout_width="wrap_content"
            android:layout_height="52dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:text="RESET LEVEL"
            android:textAllCaps="true"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="14sp"
            android:backgroundTint="#C62828"
            android:elevation="6dp"
            android:stateListAnimator="@null" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/ad_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="50dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Settings Overlay -->
    <include
        android:id="@+id/layout_settings"
        layout="@layout/dialog_settings"
        android:visibility="gone" />

    <!-- Win Dialog Overlay -->
    <include
        android:id="@+id/layout_win_dialog"
        layout="@layout/dialog_win"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

</androidx.constraintlayout.widget.ConstraintLayout>