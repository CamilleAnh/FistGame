<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/backgroup_fragment_second"
    tools:context=".LevelOneFragment">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/safe_top_guideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_begin="48dp" />

    <!-- Back Button -->
    <ImageView
        android:id="@+id/iv_back"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="12dp"
        android:contentDescription="Back"
        android:padding="8dp"
        android:src="@drawable/ic_prev"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/safe_top_guideline"
        app:tint="#FFFFFF" />

    <!-- Level Title with Frame -->
    <TextView
        android:id="@+id/tv_level_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/level_title_bg"
        android:fontFamily="sans-serif-black"
        android:paddingStart="24dp"
        android:paddingTop="8dp"
        android:paddingEnd="24dp"
        android:paddingBottom="8dp"
        android:text="Level 1"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:shadowColor="#000000"
        android:shadowDx="2"
        android:shadowDy="2"
        android:shadowRadius="2"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/safe_top_guideline" />

    <!-- Gold Display with Frame -->
    <TextView
        android:id="@+id/tv_game_gold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/glass_panel_bg"
        android:fontFamily="sans-serif-medium"
        android:paddingStart="16dp"
        android:paddingTop="4dp"
        android:paddingEnd="16dp"
        android:paddingBottom="4dp"
        android:text="🪙 0"
        android:textColor="#FFD54F"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_level_name" />

    <!-- Menu Button -->
    <ImageButton
        android:id="@+id/btn_settings"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="14dp"
        android:background="@drawable/bg_menu_btn"
        android:src="@drawable/ic_menu"
        android:padding="8dp"
        android:contentDescription="Menu"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/safe_top_guideline"
        app:tint="#FFFFFF" />

    <!-- Progress Text with Frame -->
    <TextView
        android:id="@+id/tv_packed_progress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/glass_panel_bg"
        android:gravity="center"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:text="..."
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_game_gold" />

    <!-- Bags Display Area -->
    <LinearLayout
        android:id="@+id/ll_boxes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toBottomOf="@id/tv_packed_progress">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/truck_container_a"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp">
            
            <ImageView
                android:id="@+id/img_truck_a"
                android:layout_width="match_parent"
                android:layout_height="85dp"
                android:src="@drawable/truck_blue_photoroom"
                android:scaleType="fitCenter"
                app:layout_constraintTop_toTopOf="parent" />
                
            <TextView
                android:id="@+id/tv_box_a_fruit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="32sp"
                android:shadowColor="#000000"
                android:shadowDx="2"
                android:shadowDy="2"
                android:shadowRadius="4"
                app:layout_constraintTop_toTopOf="@id/img_truck_a"
                app:layout_constraintBottom_toBottomOf="@id/img_truck_a"
                app:layout_constraintStart_toStartOf="@id/img_truck_a"
                app:layout_constraintEnd_toEndOf="@id/img_truck_a"
                app:layout_constraintHorizontal_bias="0.22"
                app:layout_constraintVertical_bias="0.25" />

            <TextView
                android:id="@+id/tv_box_a_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/glass_panel_bg"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                app:layout_constraintTop_toBottomOf="@id/img_truck_a"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:id="@+id/tv_box_a_turns"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFEB3B"
                android:textSize="14sp"
                android:textStyle="bold"
                android:shadowColor="#000000"
                android:shadowDx="1"
                android:shadowDy="1"
                android:shadowRadius="2"
                app:layout_constraintTop_toTopOf="@id/img_truck_a"
                app:layout_constraintBottom_toBottomOf="@id/img_truck_a"
                app:layout_constraintStart_toStartOf="@id/img_truck_a"
                app:layout_constraintEnd_toEndOf="@id/img_truck_a"
                app:layout_constraintHorizontal_bias="0.75"
                app:layout_constraintVertical_bias="0.30" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/truck_container_b"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp">
            
            <ImageView
                android:id="@+id/img_truck_b"
                android:layout_width="match_parent"
                android:layout_height="85dp"
                android:src="@drawable/truck_blue_photoroom"
                android:scaleType="fitCenter"
                app:layout_constraintTop_toTopOf="parent" />
                
            <TextView
                android:id="@+id/tv_box_b_fruit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="32sp"
                android:shadowColor="#000000"
                android:shadowDx="2"
                android:shadowDy="2"
                android:shadowRadius="4"
                app:layout_constraintTop_toTopOf="@id/img_truck_b"
                app:layout_constraintBottom_toBottomOf="@id/img_truck_b"
                app:layout_constraintStart_toStartOf="@id/img_truck_b"
                app:layout_constraintEnd_toEndOf="@id/img_truck_b"
                app:layout_constraintHorizontal_bias="0.22"
                app:layout_constraintVertical_bias="0.25" />

            <TextView
                android:id="@+id/tv_box_b_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/glass_panel_bg"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                app:layout_constraintTop_toBottomOf="@id/img_truck_b"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:id="@+id/tv_box_b_turns"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFEB3B"
                android:textSize="14sp"
                android:textStyle="bold"
                android:shadowColor="#000000"
                android:shadowDx="1"
                android:shadowDy="1"
                android:shadowRadius="2"
                app:layout_constraintTop_toTopOf="@id/img_truck_b"
                app:layout_constraintBottom_toBottomOf="@id/img_truck_b"
                app:layout_constraintStart_toStartOf="@id/img_truck_b"
                app:layout_constraintEnd_toEndOf="@id/img_truck_b"
                app:layout_constraintHorizontal_bias="0.75"
                app:layout_constraintVertical_bias="0.30" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </LinearLayout>

    <!-- Game Board (3D Stacking Frame) -->
    <FrameLayout
        android:id="@+id/gl_game_board"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:clipChildren="false"
        app:layout_constraintBottom_toTopOf="@id/ll_powerups"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ll_boxes" />

    <!-- Powerups -->
    <LinearLayout
        android:id="@+id/ll_powerups"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toTopOf="@id/ad_container">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_reroll_bags"
            android:layout_width="100dp"
            android:layout_height="64dp"
            android:layout_margin="8dp"
            android:background="@drawable/powerup_button_bg"
            android:text="🎲"
            android:textSize="22sp"
            android:elevation="8dp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_magnify"
            android:layout_width="100dp"
            android:layout_height="64dp"
            android:layout_margin="8dp"
            android:background="@drawable/powerup_button_bg"
            android:text="🔍"
            android:textSize="22sp"
            android:elevation="8dp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_reshuffle"
            android:layout_width="100dp"
            android:layout_height="64dp"
            android:layout_margin="8dp"
            android:background="@drawable/powerup_button_bg"
            android:text="🔀"
            android:textSize="22sp"
            android:elevation="8dp" />

    </LinearLayout>

    <!-- Banner Ads -->
    <FrameLayout
        android:id="@+id/ad_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Overlays -->
    <include
        android:id="@+id/layout_settings"
        layout="@layout/dialog_settings"
        android:visibility="gone" />

    <include
        android:id="@+id/layout_win_dialog"
        layout="@layout/dialog_win"
        android:visibility="gone" />

    <include
        android:id="@+id/layout_lose_dialog"
        layout="@layout/dialog_lose"
        android:visibility="gone" />

</androidx.constraintlayout.widget.ConstraintLayout>