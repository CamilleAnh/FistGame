<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/hinh_nen"
    tools:context=".FirstFragment">

    <!-- Semi-transparent overlay to make UI more readable -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#44000000" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/safe_top_guideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_begin="48dp" />

    <!-- Gold display top-right -->
    <TextView
        android:id="@+id/tv_home_gold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="16dp"
        android:text="🪙 0"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:background="@drawable/level_title_bg"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/safe_top_guideline" />

    <TextView
        android:id="@+id/tv_game_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="80dp"
        android:shadowColor="#BF000000"
        android:shadowDx="0"
        android:shadowDy="8"
        android:shadowRadius="12"
        android:text="FRUIT\nSORT"
        android:gravity="center"
        android:lineSpacingMultiplier="0.8"
        android:fontFamily="sans-serif-black"
        android:textColor="#FFFFFF"
        android:textSize="80sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Premium 2.5D Edition"
        android:textColor="#FFD54F"
        android:textSize="20sp"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.2"
        app:layout_constraintEnd_toEndOf="@+id/tv_game_title"
        app:layout_constraintStart_toStartOf="@+id/tv_game_title"
        app:layout_constraintTop_toBottomOf="@+id/tv_game_title" />

    <LinearLayout
        android:id="@+id/ll_menu"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="60dp"
        android:layout_marginBottom="80dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_play"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/powerup_button_bg"
            android:text="PLAY NOW"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:fontFamily="sans-serif-black"
            android:elevation="12dp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_shop"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/dialog_premium_bg"
            android:text="🛒 SHOP"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:fontFamily="sans-serif-black"
            android:elevation="6dp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_settings"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:background="@drawable/dialog_premium_bg"
            android:text="⚙️ SETTINGS"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:fontFamily="sans-serif-black"
            android:elevation="6dp" />

        <TextView
            android:id="@+id/tv_privacy_policy"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="24dp"
            android:text="Privacy Policy"
            android:textColor="#CCFFFFFF"
            android:textSize="12sp"
            android:padding="8dp" />

    </LinearLayout>

    <!-- Settings Overlay -->
    <include
        android:id="@+id/layout_settings"
        layout="@layout/dialog_settings"
        android:visibility="gone" />

</androidx.constraintlayout.widget.ConstraintLayout>
