<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/backgroup_fragment_second"
    tools:context=".SecondFragment">

    <!-- Container chính -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_level_container"
        android:layout_width="338dp"
        android:layout_height="601dp"
        android:layout_margin="16dp"
        android:background="@drawable/level_container_bg"
        app:layout_constraintBottom_toTopOf="@+id/guideline_h_bottom"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tv_level_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/level_title_bg"
            android:paddingHorizontal="32dp"
            android:paddingVertical="10dp"
            android:text="SELECT STAGE"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Grid các level -->
        <GridLayout
            android:id="@+id/gl_levels"
            android:layout_width="293dp"
            android:layout_height="357dp"
            android:layout_marginVertical="12dp"
            android:columnCount="4"
            android:rowCount="5"
            android:useDefaultMargins="true"
            app:layout_constraintBottom_toTopOf="@+id/btn_next"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tv_level_title">

            <!-- 20 slots -->
            <FrameLayout
                android:layout_width="65dp"
                android:layout_height="65dp"
                android:layout_margin="4dp" />

            <FrameLayout
                android:layout_width="65dp"
                android:layout_height="65dp"
                android:layout_margin="4dp" />

            <FrameLayout
                android:layout_width="65dp"
                android:layout_height="65dp"
                android:layout_margin="4dp" />

            <FrameLayout
                android:layout_width="65dp"
                android:layout_height="65dp"
                android:layout_margin="4dp" />

            <FrameLayout
                android:layout_width="65dp"
                android:layout_height="65dp"
                android:layout_margin="4dp" />

            <FrameLayout
                android:layout_width="65dp"
                android:layout_height="65dp"
                android:layout_margin="4dp" />

            <FrameLayout
                android:layout_width="65dp"
                android:layout_height="65dp"
                android:layout_margin="4dp" />

            <FrameLayout
                android:layout_width="65dp"
                android:layout_height="65dp"
                android:layout_margin="4dp" />

            <FrameLayout
                android:layout_width="65dp"
                android:layout_height="65dp"
                android:layout_margin="4dp" />

            <FrameLayout
                android:layout_width="65dp"
                android:layout_height="65dp"
                android:layout_margin="4dp" />

            <FrameLayout
                android:layout_width="65dp"
                android:layout_height="65dp"
                android:layout_margin="4dp" />

            <FrameLayout
                android:layout_width="65dp"
                android:layout_height="65dp"
                android:layout_margin="4dp" />

            <FrameLayout
                android:layout_width="65dp"
                android:layout_height="65dp"
                android:layout_margin="4dp" />

            <FrameLayout
                android:layout_width="65dp"
                android:layout_height="65dp"
                android:layout_margin="4dp" />

            <FrameLayout
                android:layout_width="65dp"
                android:layout_height="65dp"
                android:layout_margin="4dp" />

            <FrameLayout
                android:layout_width="65dp"
                android:layout_height="65dp"
                android:layout_margin="4dp" />

            <FrameLayout
                android:layout_width="65dp"
                android:layout_height="65dp"
                android:layout_margin="4dp" />

            <FrameLayout
                android:layout_width="65dp"
                android:layout_height="65dp"
                android:layout_margin="4dp" />

            <FrameLayout
                android:layout_width="65dp"
                android:layout_height="65dp"
                android:layout_margin="4dp" />

            <FrameLayout
                android:layout_width="65dp"
                android:layout_height="65dp"
                android:layout_margin="4dp" />

        </GridLayout>

        <ImageButton
            android:id="@+id/btn_prev"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginStart="24dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/level_item_unlocked"
            android:src="@android:drawable/ic_media_previous"
            app:backgroundTint="#FFB300"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:tint="#FFFFFF" />

        <ImageButton
            android:id="@+id/btn_next"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/level_item_unlocked"
            android:src="@android:drawable/ic_media_next"
            app:backgroundTint="#FFB300"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:tint="#FFFFFF" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_h_bottom"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.82" />

    <ImageButton
        android:id="@+id/btn_back_home"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:background="@drawable/level_item_unlocked"
        android:src="@android:drawable/ic_menu_revert"
        app:backgroundTint="#EF5350"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/guideline_v"
        app:layout_constraintHorizontal_bias="0.551"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/guideline_h_bottom"
        app:layout_constraintVertical_bias="0.0"
        app:tint="#FFFFFF" />

    <ImageButton
        android:id="@+id/btn_start_game"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:background="@drawable/level_item_unlocked"
        android:src="@android:drawable/ic_media_play"
        app:backgroundTint="#66BB6A"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.488"
        app:layout_constraintStart_toStartOf="@+id/guideline_v"
        app:layout_constraintTop_toBottomOf="@+id/guideline_h_bottom"
        app:layout_constraintVertical_bias="0.0"
        app:tint="#FFFFFF" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_v"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.5" />

</androidx.constraintlayout.widget.ConstraintLayout>
