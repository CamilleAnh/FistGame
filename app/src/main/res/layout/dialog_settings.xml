<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#80000000"
    android:clickable="true"
    android:focusable="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/settings_card"
        android:layout_width="320dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/dialog_premium_bg"
        android:padding="24dp"
        android:elevation="24dp">

        <TextView
            android:id="@+id/tv_settings_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SETTINGS"
            android:textColor="#FFD54F"
            android:textSize="28sp"
            android:fontFamily="sans-serif-black"
            android:shadowColor="#000000"
            android:shadowDx="2"
            android:shadowDy="2"
            android:shadowRadius="4"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <ImageButton
            android:id="@+id/btn_close_settings"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/powerup_button_bg"
            app:backgroundTint="#FF5252"
            android:src="@drawable/ic_close"
            android:padding="10dp"
            android:scaleType="fitCenter"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:tint="#FFFFFF" />

        <LinearLayout
            android:id="@+id/ll_music"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/tv_settings_title">

            <TextView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:text="🎵"
                android:textSize="24sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="@string/music_label"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:fontFamily="sans-serif-medium" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switch_music"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:thumbTint="#FFD54F"
                app:trackTint="#66FFD54F" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/ll_sound"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/ll_music">

            <TextView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:text="🔊"
                android:textSize="24sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="@string/sound_label"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:fontFamily="sans-serif-medium" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switch_sound"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:thumbTint="#FFD54F"
                app:trackTint="#66FFD54F" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/ll_vibration"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/ll_sound">

            <TextView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:text="📳"
                android:textSize="24sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="@string/vibration_label"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:fontFamily="sans-serif-medium" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switch_vibration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:thumbTint="#FFD54F"
                app:trackTint="#66FFD54F" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/ll_language"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/ll_vibration">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_lang_en"
                android:layout_width="120dp"
                android:layout_height="48dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/powerup_button_bg"
                android:text="English"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:fontFamily="sans-serif-black"
                android:elevation="4dp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_lang_vi"
                android:layout_width="120dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/powerup_button_bg"
                android:text="Tiếng Việt"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:fontFamily="sans-serif-black"
                android:elevation="4dp" />
        </LinearLayout>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_reset_all"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@android:color/transparent"
            android:text="@string/reset_settings_label"
            android:textColor="#BBFFFFFF"
            android:textSize="12sp"
            android:textAllCaps="false"
            app:layout_constraintTop_toBottomOf="@id/ll_language"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>