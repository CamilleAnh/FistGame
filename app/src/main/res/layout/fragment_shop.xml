<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/back">

    <!-- Header Bar -->
    <FrameLayout
        android:id="@+id/shop_header"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:background="#CC0D0D1A"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Back button -->
        <ImageButton
            android:id="@+id/btn_shop_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="start|center_vertical"
            android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_prev"
            app:tint="#FFFFFF" />

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/shop_title"
            android:textColor="#FFD54F"
            android:textSize="22sp"
            android:textStyle="bold"
            android:shadowColor="#000000"
            android:shadowDx="2"
            android:shadowDy="2"
            android:shadowRadius="3" />

        <!-- Gold display -->
        <TextView
            android:id="@+id/tv_shop_gold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="16dp"
            android:text="🪙 0"
            android:textColor="#FFD54F"
            android:textSize="16sp"
            android:textStyle="bold" />

    </FrameLayout>

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/shop_header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="24dp">

            <!-- ============================== -->
            <!-- Section: Premium (Remove Ads) -->
            <!-- ============================== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"
                android:text="@string/shop_section_premium"
                android:textColor="#FFFFD54F"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <!-- Remove Ads Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_remove_ads"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardBackgroundColor="#1A1A2E"
                app:cardCornerRadius="20dp"
                app:cardElevation="12dp">

                <!-- Gold gradient border via background -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="2dp"
                    android:background="#FFD54F">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:background="#1A1A2E">

                        <!-- Title row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/shop_remove_ads_title"
                                android:textColor="#FFFFFF"
                                android:textSize="20sp"
                                android:textStyle="bold" />

                            <!-- Active badge (hidden by default) -->
                            <TextView
                                android:id="@+id/tv_remove_ads_active_badge"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="✅ ĐÃ MUA"
                                android:textColor="#A5D6A7"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:visibility="gone" />

                        </LinearLayout>

                        <!-- Description -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="@string/shop_remove_ads_desc"
                            android:textColor="#AAFFFFFF"
                            android:textSize="12sp"
                            android:lineSpacingExtra="2dp" />

                        <!-- Benefits list -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="● Xoá Banner Ad vĩnh viễn&#10;● Xoá Interstitial giữa các màn&#10;● Tự động nhận Rewarded không cần xem"
                            android:textColor="#FFD54F"
                            android:textSize="12sp"
                            android:lineSpacingExtra="3dp" />

                        <!-- Buy button -->
                        <Button
                            android:id="@+id/btn_buy_remove_ads"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:layout_marginTop="14dp"
                            android:text="@string/shop_remove_ads_loading"
                            android:textAllCaps="false"
                            android:textColor="#1A1A2E"
                            android:textStyle="bold"
                            android:textSize="16sp"
                            android:backgroundTint="#FFD54F"
                            android:stateListAnimator="@null"
                            android:elevation="6dp" />

                        <!-- Restore link -->
                        <TextView
                            android:id="@+id/tv_restore_purchases"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:layout_marginTop="10dp"
                            android:text="@string/shop_remove_ads_restore"
                            android:textColor="#66FFFFFF"
                            android:textSize="12sp"
                            android:paddingTop="6dp"
                            android:paddingBottom="6dp"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp" />

                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Section: Free Gold -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"
                android:text="🎁 VÀNG MIỄN PHÍ"
                android:textColor="#AAFFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Daily Reward Card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card_daily_claim"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardBackgroundColor="#2E7D32"
                    app:cardCornerRadius="16dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="HÀNG NGÀY"
                            android:textColor="#FFFFFF"
                            android:textSize="12sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:id="@+id/tv_daily_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="+100 🪙"
                            android:textColor="#FFD54F"
                            android:textSize="16sp"
                            android:textStyle="bold"/>
                        <Button
                            android:id="@+id/btn_claim_daily"
                            android:layout_width="match_parent"
                            android:layout_height="36dp"
                            android:layout_marginTop="8dp"
                            android:text="NHẬN"
                            android:textSize="12sp"
                            android:backgroundTint="#FFD54F"
                            android:textColor="#1B5E20"
                            android:padding="0dp"
                            android:stateListAnimator="@null"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Watch Ad Card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card_watch_ad"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    app:cardBackgroundColor="#1565C0"
                    app:cardCornerRadius="16dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="XEM QUẢNG CÁO"
                            android:textColor="#FFFFFF"
                            android:textSize="12sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:id="@+id/tv_ad_limit"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="10/10 lượt"
                            android:textColor="#FFD54F"
                            android:textSize="14sp"/>
                        <Button
                            android:id="@+id/btn_watch_ad_gold"
                            android:layout_width="match_parent"
                            android:layout_height="36dp"
                            android:layout_marginTop="8dp"
                            android:text="+100 🪙"
                            android:textSize="12sp"
                            android:backgroundTint="#FFD54F"
                            android:textColor="#0D47A1"
                            android:padding="0dp"
                            android:stateListAnimator="@null"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- Section: Power-ups -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"
                android:text="⚡ ĐỒ HỖ TRỢ (POWER-UPS)"
                android:textColor="#AAFFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <!-- Card: Reroll -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_reroll"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="#1E1E3A"
                app:cardCornerRadius="16dp"
                app:cardElevation="8dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tv_reroll_name"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/shop_item_reroll_name"
                        android:textColor="#FFFFFF"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toStartOf="@+id/btn_buy_reroll"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tv_reroll_desc"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/shop_item_reroll_desc"
                        android:textColor="#88FFFFFF"
                        android:textSize="12sp"
                        app:layout_constraintEnd_toStartOf="@+id/btn_buy_reroll"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tv_reroll_name" />

                    <TextView
                        android:id="@+id/tv_reroll_owned"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Đang có: 0"
                        android:textColor="#FFD54F"
                        android:textSize="12sp"
                        app:layout_constraintEnd_toStartOf="@+id/btn_buy_reroll"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tv_reroll_desc" />

                    <Button
                        android:id="@+id/btn_buy_reroll"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:text="100 🪙"
                        android:textAllCaps="false"
                        android:textColor="#1A1A2E"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:backgroundTint="#E65100"
                        android:stateListAnimator="@null"
                        android:elevation="4dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card: Reveal -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_reveal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="#1E1E3A"
                app:cardCornerRadius="16dp"
                app:cardElevation="8dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tv_reveal_name"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/shop_item_reveal_name"
                        android:textColor="#FFFFFF"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toStartOf="@+id/btn_buy_reveal"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tv_reveal_desc"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/shop_item_reveal_desc"
                        android:textColor="#88FFFFFF"
                        android:textSize="12sp"
                        app:layout_constraintEnd_toStartOf="@+id/btn_buy_reveal"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tv_reveal_name" />

                    <TextView
                        android:id="@+id/tv_reveal_owned"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Đang có: 0"
                        android:textColor="#FFD54F"
                        android:textSize="12sp"
                        app:layout_constraintEnd_toStartOf="@+id/btn_buy_reveal"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tv_reveal_desc" />

                    <Button
                        android:id="@+id/btn_buy_reveal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:text="150 🪙"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:backgroundTint="#0D47A1"
                        android:stateListAnimator="@null"
                        android:elevation="4dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card: Shuffle -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_shuffle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="#1E1E3A"
                app:cardCornerRadius="16dp"
                app:cardElevation="8dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tv_shuffle_name"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/shop_item_shuffle_name"
                        android:textColor="#FFFFFF"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toStartOf="@+id/btn_buy_shuffle"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tv_shuffle_desc"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/shop_item_shuffle_desc"
                        android:textColor="#88FFFFFF"
                        android:textSize="12sp"
                        app:layout_constraintEnd_toStartOf="@+id/btn_buy_shuffle"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tv_shuffle_name" />

                    <TextView
                        android:id="@+id/tv_shuffle_owned"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Đang có: 0"
                        android:textColor="#FFD54F"
                        android:textSize="12sp"
                        app:layout_constraintEnd_toStartOf="@+id/btn_buy_shuffle"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tv_shuffle_desc" />

                    <Button
                        android:id="@+id/btn_buy_shuffle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:text="200 🪙"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:backgroundTint="#6A1B9A"
                        android:stateListAnimator="@null"
                        android:elevation="4dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

            <!-- Hint text -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_gravity="center"
                android:text="💡 Kiếm vàng bằng cách thắng màn chơi!"
                android:textColor="#55FFFFFF"
                android:textSize="12sp"
                android:gravity="center" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
