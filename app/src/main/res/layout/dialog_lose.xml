<?xml version="1.0" encoding="utf-8"?>
<!-- Lose Dialog Overlay – hiện khi người chơi hết đường đi / hết lượt -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CC000000"
    android:clickable="true"
    android:focusable="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/lose_card"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/dialog_premium_lose_bg"
        android:padding="32dp"
        android:elevation="30dp">

        <TextView
            android:id="@+id/tv_lose_emoji"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💔"
            android:textSize="64sp"
            android:shadowColor="#FF7043"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="15"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_lose_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="STUCK!"
            android:textColor="#FF7043"
            android:textSize="34sp"
            android:fontFamily="sans-serif-black"
            android:shadowColor="#000000"
            android:shadowDx="3"
            android:shadowDy="3"
            android:shadowRadius="6"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_lose_emoji" />

        <TextView
            android:id="@+id/tv_lose_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="No more moves left..."
            android:textColor="#CCFFFFFF"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_lose_title" />

        <View
            android:id="@+id/lose_divider"
            android:layout_width="60dp"
            android:layout_height="3dp"
            android:layout_marginTop="20dp"
            android:background="#FF7043"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_lose_subtitle" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_lose_retry"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/powerup_button_bg"
            app:backgroundTint="#FF7043"
            android:text="TRY AGAIN"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:fontFamily="sans-serif-black"
            android:elevation="6dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/lose_divider" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_lose_back"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/powerup_button_bg"
            app:backgroundTint="#44FFFFFF"
            android:text="QUIT"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:fontFamily="sans-serif-black"
            android:elevation="4dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btn_lose_retry" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>
