<?xml version="1.0" encoding="utf-8"?>
<!-- Win Dialog Overlay – hiện khi người chơi thắng màn -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CC000000"
    android:clickable="true"
    android:focusable="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/win_card"
        android:layout_width="320dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/dialog_premium_bg"
        android:padding="28dp"
        android:elevation="30dp">

        <!-- Glowing Star Effect -->
        <TextView
            android:id="@+id/tv_win_stars"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✨ ⭐ ⭐ ⭐ ✨"
            android:textSize="32sp"
            android:letterSpacing="0.1"
            android:shadowColor="#FFD54F"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="15"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Premium Title -->
        <TextView
            android:id="@+id/tv_win_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="VICTORY!"
            android:textColor="#FFD54F"
            android:textSize="34sp"
            android:fontFamily="sans-serif-black"
            android:shadowColor="#000000"
            android:shadowDx="3"
            android:shadowDy="3"
            android:shadowRadius="6"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_win_stars" />

        <TextView
            android:id="@+id/tv_win_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Level Complete!"
            android:textColor="#CCFFFFFF"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_win_title" />

        <View
            android:id="@+id/win_divider"
            android:layout_width="60dp"
            android:layout_height="3dp"
            android:layout_marginTop="20dp"
            android:background="#FFD54F"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_win_subtitle" />

        <TextView
            android:id="@+id/tv_win_reward_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="COLLECT YOUR REWARD"
            android:textColor="#AAFFFFFF"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/win_divider" />

        <!-- Buttons Row -->
        <LinearLayout
            android:id="@+id/ll_buttons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal"
            android:weightSum="2"
            app:layout_constraintTop_toBottomOf="@id/tv_win_reward_label">

            <LinearLayout
                android:id="@+id/ll_continue_btn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:orientation="vertical">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_win_continue"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:background="@drawable/powerup_button_bg"
                    app:backgroundTint="#4CAF50"
                    android:text="NEXT"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-black"
                    android:elevation="6dp" />

                <TextView
                    android:id="@+id/tv_continue_reward"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="6dp"
                    android:text="🪙 +50"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/ll_x3_btn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:orientation="vertical">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_win_watch_x3"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:background="@drawable/powerup_button_bg"
                    app:backgroundTint="#FFD54F"
                    android:text="🎁 X3"
                    android:textColor="#1A1A2E"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-black"
                    android:elevation="6dp" />

                <TextView
                    android:id="@+id/tv_x3_reward"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="6dp"
                    android:text="🪙 +150"
                    android:textColor="#FFD54F"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <ProgressBar
            android:id="@+id/pb_win_loading"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginTop="16dp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ll_buttons" />

        <TextView
            android:id="@+id/tv_win_watching"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Loading reward..."
            android:textColor="#AAFFFFFF"
            android:textSize="12sp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/pb_win_loading" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>
